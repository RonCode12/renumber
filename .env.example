DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# Login gate for the whole app (defaults to renumber / medias if unset)
BASIC_AUTH_USER="renumber"
BASIC_AUTH_PASSWORD="medias"

# Second login gate for /admin only (defaults to yon / 654321 if unset)
ADMIN_AUTH_USER="yon"
ADMIN_AUTH_PASSWORD="654321"

AUTH_SESSION_SECRET="change-me-to-a-long-random-string"
